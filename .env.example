# ═══ DATABASE ═══
DATABASE_URL=postgres://postgres:postgres@localhost:5432/queroplantao

# ═══ AMQP ═══
AMQP_URL=amqp://guest:guest@localhost:5672
AMQP_QUEUE=wpp.actions
AMQP_PREFETCH=5                              # mensagens processadas simultaneamente antes do ACK
AMQP_RETRY_DELAY_MS=120000                   # TTL (ms) da fila de retry — delay antes de cada re-tentativa
AMQP_RETRY_MAX_RETRIES=3                     # número máximo de retries antes de ir para a DLQ
# AMQP_DLQ_NAME=wpp.actions.dlq              # opcional — default = ${AMQP_QUEUE}.dlq

# ═══ HTTP ═══
HTTP_PORT=3000
HTTP_API_KEY=troque-por-uma-chave-segura     # autenticação do endpoint POST /tasks

# ═══ WORKER ═══
WORKER_HEALTH_PORT=3001                      # health check usado pelo Coolify / Docker HEALTHCHECK

# ═══ REDIS ═══
REDIS_URL=redis://localhost:6379

# ═══ Z-API ═══
ZAPI_BASE_URL=https://api.z-api.io
ZAPI_CLIENT_TOKEN=SEU_CLIENT_TOKEN

# ═══ QP ADMIN API ═══
QP_ADMIN_API_URL=https://admin.queroplanao.local
QP_ADMIN_API_TOKEN=seu-token-secreto-aqui   # MESSAGE_ANALYSIS_WORKER_SECRET

# ═══ AI — PROVIDERS ═══
OPENAI_API_KEY=sk-abc123...                 # OpenAI (GPT-4o, GPT-4o-mini, etc.)
ANTHROPIC_API_KEY=sk-ant-abc123...          # Anthropic (Claude)
GOOGLE_GENERATIVE_AI_API_KEY=AIza...        # Google (Gemini)

# ═══ AI — MODELOS ═══
# Formato: "provider/model-name" — ex: "openai/gpt-4o-mini", "anthropic/claude-sonnet-4-20250514", "google/gemini-2.0-flash"
AI_MODEL_ANALYZE_MESSAGE=openai/gpt-4o-mini

# ═══ SPAM WATCHER ═══
SPAM_FILTERS=https://tk7.games,bit.ly       # textos a filtrar, separados por vírgula
SPAM_INTERVAL_MS=120000                     # intervalo entre execuções (ms)
