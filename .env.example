# URL de conexão com o banco de dados PostgreSQL
DATABASE_URL=postgres://user:password@localhost:5432/dbname

# URL de conexão AMQP (LavinMQ / RabbitMQ)
AMQP_URL=amqp://guest:guest@localhost:5672

# Nome da fila a ser consumida
AMQP_QUEUE=wpp.actions

# Quantas mensagens o worker processa simultaneamente antes de aguardar ACK
AMQP_PREFETCH=5

# URL base da Z-API (sem trailing slash)
ZAPI_BASE_URL=https://api.z-api.io

# Lista de instâncias Z-API em formato JSON
# Cada objeto deve conter: instance_id, instance_token, client_token
ZAPI_INSTANCES=[{"instance_id":"SUA_INSTANCIA","instance_token":"SEU_TOKEN","client_token":"SEU_CLIENT_TOKEN"}]

# Concorrência por instância Z-API (total = valor × número de instâncias)
ZAPI_CONCURRENCY_PER_INSTANCE=1

# Delay aleatório (ms) entre requisições à Z-API — gera jitter para evitar rajadas
ZAPI_DELAY_MIN_MS=500
ZAPI_DELAY_MAX_MS=1800

# Porta do servidor HTTP (0 = porta aleatória, útil em testes)
HTTP_PORT=3000

# Chave de autenticação para o endpoint POST /tasks
HTTP_API_KEY=troque-por-uma-chave-segura

# spam-watcher: lista de textos a filtrar, separados por vírgula
SPAM_FILTERS=https://tk7.games,bit.ly

# spam-watcher: intervalo entre execuções em ms (default: 120000 = 2 min)
SPAM_INTERVAL_MS=120000
