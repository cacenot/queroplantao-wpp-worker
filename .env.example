# ═══ RUNTIME ═══
# Lidas direto via process.env (fora do schema Zod) pra não quebrar o logger
# quando a validação de env falha — o logger precisa estar disponível pra reportar o erro.
# NODE_ENV=production                          # afeta formato de logs (pretty em dev, json em prod)
# LOG_LEVEL=info                               # pino: trace | debug | info | warn | error

# ═══ DATABASE ═══
DATABASE_URL=postgres://postgres:secret@localhost:5432/queroplantao_messaging

# ═══ AMQP ═══
AMQP_URL=amqp://guest:guest@localhost:5672
# ── whatsapp-zapi worker (delete_message + remove_participant, x-max-priority=10) ──
# AMQP_ZAPI_QUEUE=messaging.zapi
# AMQP_ZAPI_PREFETCH=1                         # serial — lease Z-API coordena acesso por provider
# ── moderation worker (moderate_group_message) ──
# AMQP_MODERATION_QUEUE=messaging.moderation
# AMQP_MODERATION_PREFETCH=5                   # LLM paralelo
# AMQP_RETRY_DELAY_MS=120000                   # TTL (ms) da fila de retry — delay antes de cada re-tentativa
# AMQP_RETRY_MAX_RETRIES=3                     # número máximo de retries antes de ir para a DLQ

# ═══ REDIS ═══
REDIS_URL=redis://localhost:6379

# ═══ HTTP / WORKER ═══
# HTTP_PORT=3000
HTTP_API_KEY=troque-por-uma-chave-segura     # autenticação do endpoint POST /tasks
# WORKER_ZAPI_HEALTH_PORT=3011                 # health check do whatsapp-zapi worker
# WORKER_MODERATION_HEALTH_PORT=3012           # health check do moderation worker

# ═══ Z-API ═══
ZAPI_BASE_URL=https://api.z-api.io
ZAPI_CLIENT_TOKEN=SEU_CLIENT_TOKEN
# ZAPI_DELAY_MIN_MS=2500                       # delay mínimo (ms) entre requisições — jitter anti-rajada
# ZAPI_DELAY_MAX_MS=5200                       # delay máximo (ms)
# ZAPI_SAFETY_TTL_MS=30000                     # TTL da lease distribuída por provider (ms)
# ZAPI_HEARTBEAT_INTERVAL_MS=10000             # intervalo de renovação da lease (ms) — deve ser < ZAPI_SAFETY_TTL_MS
# ZAPI_REQUEST_TIMEOUT_MS=10000               # timeout por request HTTP (ms) — timeout é retryable

# ═══ WEBHOOKS ═══
# ZAPI_RECEIVED_WEBHOOK_ENABLED=true
ZAPI_RECEIVED_WEBHOOK_SECRET=seu-webhook-secret-aqui

# ═══ QP ADMIN API ═══
QP_ADMIN_API_URL=https://app.queroplantao.com.br
QP_ADMIN_API_TOKEN=seu-token-secreto-aqui        # MESSAGE_ANALYSIS_WORKER_SECRET
QP_ADMIN_API_SERVICE_TOKEN=seu-service-token-aqui  # header X-Service-Token para identificação no firewall

# ═══ AI ═══
# Apenas o provider ativo precisa estar definido — lido implicitamente pelo Vercel AI SDK
# OPENAI_API_KEY=sk-abc123...
# ANTHROPIC_API_KEY=sk-ant-abc123...
# GOOGLE_GENERATIVE_AI_API_KEY=AIza...

# ═══ MODERAÇÃO ═══
# primaryModel / escalationModel / version / examples vivem em `src/ai/moderation/versions/*.md`.
# Ver src/ai/moderation/active.ts pra versão em uso; troca exige redeploy.
# MODERATION_CONTENT_FILTER_ENABLED=false     # filtro determinístico antes do LLM (segunda porta de enforcement)
# INGESTION_DEDUPE_WINDOW_MS=60000            # janela (ms) para colapsar a mesma mensagem em várias instâncias Z-API
# MODERATION_REUSE_WINDOW_MS=1296000000       # janela (ms) de reuso por contentHash+version (default: 15 dias)
# MESSAGING_GROUPS_REDIS_PREFIX=messaging_groups

# ═══ SCRIPTS ═══
# spam-watcher
# SPAM_FILTERS=https://tk7.games,bit.ly       # textos a filtrar, separados por vírgula
# SPAM_INTERVAL_MS=120000                     # intervalo entre execuções (ms)

# seed-initial — opcional. Se omitido, pula criação de instâncias Z-API.
# SEED_DATA_JSON={"instances":[{"displayName":"Prod-01","zapiInstanceId":"INSTANCE_ID","instanceToken":"INSTANCE_TOKEN","customClientToken":null}]}

# ═══ SENTRY ═══
# SENTRY_DSN=https://<key>@<org>.ingest.sentry.io/<project>   # opcional — sem DSN o init vira no-op
# SENTRY_ENVIRONMENT=production               # tag de ambiente nos eventos
# SENTRY_RELEASE=                             # opcional — sha do commit para correlacionar com release
# SENTRY_TRACES_SAMPLE_RATE=0.1               # fração de transações amostradas (0–1)
# SENTRY_PROFILES_SAMPLE_RATE=0               # fração de profiles amostrados (0–1)
