{
  "uid": "lavinmq-overview",
  "title": "LavinMQ Overview",
  "tags": ["lavinmq", "amqp"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "time": { "from": "now-3h", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Mensagens prontas por fila",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "lavinmq_detailed_queue_messages_ready",
          "legendFormat": "{{queue}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Mensagens não-ack por fila",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "lavinmq_detailed_queue_messages_unacked",
          "legendFormat": "{{queue}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Consumers por fila",
      "description": "Métrica exposta pela family `queue_consumer_count` no endpoint `/metrics/detailed`. Se o painel exibir \"No data\", rodar `curl 'http://lavinmq:15692/metrics/detailed?family=queue_consumer_count'` e ajustar o `expr` para o nome real do metric (provavelmente `lavinmq_detailed_queue_consumers`).",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "lavinmq_detailed_queue_consumers",
          "legendFormat": "{{queue}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Taxa global delivered vs acknowledged (msg/s)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(lavinmq_global_messages_delivered_total[1m])",
          "legendFormat": "delivered"
        },
        {
          "refId": "B",
          "expr": "rate(lavinmq_global_messages_acknowledged_total[1m])",
          "legendFormat": "acknowledged"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] }
    }
  ]
}
