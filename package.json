{
  "name": "queroplantao-wpp-worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun --watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint ./src",
    "format": "biome format --write ./src",
    "check": "biome check --write ./src",
    "infra": "docker compose up -d",
    "remove-spam": "bun run src/scripts/remove-spam.ts",
    "remove-by-phone": "bun run src/scripts/remove-by-phone.ts",
    "spam-watcher": "bun run src/scripts/spam-watcher.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.69",
    "@ai-sdk/google": "^3.0.62",
    "@ai-sdk/openai": "^3.0.52",
    "ai": "^6.0.158",
    "p-queue": "^8.0.1",
    "pino": "^9.5.0",
    "postgres": "^3.4.9",
    "rabbitmq-client": "^5.0.8",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "bun-types": "latest",
    "typescript": "^5.7.3"
  },
  "trustedDependencies": [
    "@biomejs/biome"
  ]
}
